# ============================================================
# HaloSave API — Environment Variables (Railway service)
# Copy to .env for local dev, or set in Railway → Variables.
# ============================================================

# --- REQUIRED: Auth signing secret ---
# Server REFUSES TO BOOT without a strong value (min 16 chars).
# Generate:  openssl rand -hex 32
JWT_SECRET=""

# --- REQUIRED: Database ---
# Railway: reference the Postgres service ->  ${{Postgres.DATABASE_URL}}
DATABASE_URL=""
# Set "true" ONLY if your DB explicitly does not use SSL (rare on managed hosts).
PGSSL_DISABLE="false"

# --- Local dev only (used if DATABASE_URL is not set) ---
SQL_HOST="localhost"
SQL_USER="postgres"
SQL_PASSWORD="password"
SQL_DB_NAME="halosave_vault"

# --- Runtime ---
NODE_ENV="production"
# Railway sets PORT automatically — do NOT hardcode it.

# --- REQUIRED in production: CORS ---
# Your Netlify frontend origin(s), comma-separated. No trailing slash.
# e.g. https://halosave.netlify.app,https://halosave.app
ALLOWED_ORIGIN=""

# --- REQUIRED: Public URL of THIS API service (Railway) ---
# Used for Paystack callbacks and the sandbox checkout page.
# e.g. https://halosave-api.up.railway.app
APP_URL=""

# --- Paystack (payments) ---
PAYSTACK_SECRET_KEY=""

# --- Supabase Auth (optional — leave blank for built-in JWT auth) ---
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Gemini AI Coach (optional) ---
GEMINI_API_KEY=""

# --- Seeded super admin (used by `npm run db:seed`) ---
# If SEED_ADMIN_PASSWORD is blank, a strong random password is generated
# and printed once in the seed output.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_NAME=""
SEED_ADMIN_PASSWORD=""
SEED_DEMO_DATA="true"

# --- Fund NAV automation (optional) ---
NAV_SOURCE_URL=""
NAV_SOURCE_KEY=""
