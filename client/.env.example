# ============================================================
# HaloSave Client — Environment Variables (Netlify)
# Set these in Netlify → Site settings → Environment variables.
# ============================================================

# REQUIRED in production: your Railway API base URL (no trailing slash)
# e.g. https://halosave-api.up.railway.app
# Leave blank for local dev (Vite proxies /api to localhost:3000).
VITE_API_URL=""

# Paystack public key (frontend side)
VITE_PAYSTACK_PUBLIC_KEY=""

# Supabase Auth (optional — leave blank for built-in JWT auth)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
